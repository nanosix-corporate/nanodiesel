# ============================================================
# .env.example — COPY ini ke .env.local, lalu isi nilainya.
# File ini AMAN untuk di-commit (tidak ada nilai asli).
# JANGAN pernah commit file .env.local ke Git!
# ============================================================

# URL website (digunakan untuk sitemap.xml)
NEXT_PUBLIC_SITE_URL=https://www.nanosix.net

# Sanity CMS — Temukan di sanity.io/manage > Project Settings
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-29
